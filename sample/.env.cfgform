{
  "$cfgform": "2.0",
  "target": ".env",
  "format": "env",
  "title": "环境变量配置（.env 示例）",
  "schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "title": "环境变量",
    "description": ".env 文件的所有值在解析后均为字符串，因此字段类型统一为 string（数字/布尔用 pattern 或 enum 约束形态）。",
    "required": ["APP_ENV", "API_KEY", "DB_HOST", "DB_PASSWORD"],
    "properties": {
      "APP_ENV": {
        "type": "string",
        "enum": ["development", "production", "test"],
        "default": "production",
        "description": "运行环境。"
      },
      "API_KEY": {
        "type": "string",
        "minLength": 1,
        "description": "第三方服务 API 密钥。"
      },
      "DB_HOST": {
        "type": "string",
        "default": "localhost",
        "description": "数据库主机地址。"
      },
      "DB_PORT": {
        "type": "string",
        "pattern": "^[0-9]+$",
        "default": "5432",
        "description": "数据库端口（纯数字字符串）。"
      },
      "DB_PASSWORD": {
        "type": "string",
        "minLength": 1,
        "description": "数据库密码。"
      },
      "LOG_LEVEL": {
        "type": "string",
        "enum": ["debug", "info", "warn", "error"],
        "default": "info",
        "description": "日志级别。"
      },
      "ENABLE_METRICS": {
        "type": "string",
        "enum": ["true", "false"],
        "default": "true",
        "description": "是否上报指标（字符串 true/false）。"
      }
    }
  },
  "ui": {
    "ui:order": [
      "APP_ENV",
      "API_KEY",
      "DB_HOST",
      "DB_PORT",
      "DB_PASSWORD",
      "LOG_LEVEL",
      "ENABLE_METRICS"
    ],
    "APP_ENV": {
      "ui:widget": "radio",
      "ui:enumNames": ["开发", "生产", "测试"],
      "ui:help": "部署到线上请选「生产」。"
    },
    "API_KEY": {
      "ui:secret": true,
      "ui:help": "敏感密钥，默认掩码；其值不会写入审计日志或边车。"
    },
    "DB_HOST": {
      "ui:help": "本机数据库填 localhost。"
    },
    "DB_PORT": {
      "ui:placeholder": "5432",
      "ui:help": "PostgreSQL 默认 5432，MySQL 默认 3306。只能填数字。"
    },
    "DB_PASSWORD": {
      "ui:secret": true,
      "ui:help": "数据库密码，默认掩码；务必改掉示例默认值。"
    },
    "LOG_LEVEL": {
      "ui:enumNames": ["调试", "信息", "警告", "错误"],
      "ui:help": "排查问题时可调到「调试」。"
    },
    "ENABLE_METRICS": {
      "ui:widget": "radio",
      "ui:enumNames": ["开启", "关闭"],
      "ui:help": "是否向监控系统上报运行指标。"
    }
  },
  "meta": {
    "generatedBy": "curated/cfgform-sample",
    "generatedAt": "2026-06-20T10:15:30Z",
    "stackDetected": "generic",
    "llm": {
      "used": false,
      "model": "",
      "note": "示例边车，手工编写，演示 .env 全字符串值与 ui:secret 掩码（API_KEY/DB_PASSWORD）。"
    },
    "sources": []
  }
}
